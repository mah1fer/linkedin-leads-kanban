# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase project URL (found in: Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (found in: Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Direct DB connection (optional — used by @/lib/db.ts) ───────────────────
# PostgreSQL connection string for server-side SQL queries
# Found in: Supabase > Project Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Enrichment Plugins (all optional — free-tier fallbacks exist) ────────────

# Hunter.io API key — used by DomainIntelPlugin for email pattern detection
# Free plan: 25 searches/month — https://hunter.io
HUNTER_API_KEY=

# ZeroBounce API key — used by SmtpVerifierPlugin for email validation
# Free plan: 100 validations/month — https://www.zerobounce.net
ZEROBOUNCE_API_KEY=

# NumLookup API key — used by WhatsAppCheckerPlugin for WhatsApp detection
# Free plan available — https://www.numlookupapi.com
NUMLOOKUP_API_KEY=

# Apollo.io API key — used by ApolloPlugin for email + phone direto do profissional
# ★ RECOMENDADO para achar WhatsApp/celular de profissionais do LinkedIn
# Free plan: 50 phone reveals/month + email ilimitado — https://app.apollo.io/#/settings/integrations/api
# Como obter: Settings → Integrations → API → Create new key
APOLLO_API_KEY=
